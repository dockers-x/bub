# =============================================================================
# Bub Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the required values.
# All variables have sensible defaults where possible.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# Docker image (defaults to czyt/bub:latest)
# Available tags: latest, YYYYMMDD (date), sha-xxxxxx (commit)
# BUB_IMAGE=czyt/bub:latest

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Timezone
TZ=Asia/Shanghai

# Resource limits
BUB_CPU_LIMIT=2
BUB_MEMORY_LIMIT=4G
BUB_CPU_RESERVATION=0.5
BUB_MEMORY_RESERVATION=512M

# Logging
BUB_LOG_MAX_SIZE=10m
BUB_LOG_MAX_FILES=5

# -----------------------------------------------------------------------------
# Workspace Paths
# -----------------------------------------------------------------------------
# Default workspace (mounted as /workspace in container)
BUB_WORKSPACE_PATH=.

# Bub home directory (mounted as /data in container)
BUB_HOME=${HOME}/.bub

# Agent home directory (mounted as /root/.agents in container)
BUB_AGENT_HOME=${HOME}/.agents

# -----------------------------------------------------------------------------
# Agent Runtime
# -----------------------------------------------------------------------------
# Republic model format: provider:model_id
# Default in code is `openrouter:qwen/qwen3-coder-next`.
# BUB_MODEL=openrouter:qwen/qwen3-coder-next

# Maximum steps for agent execution
BUB_MAX_STEPS=50

# Maximum tokens for responses
BUB_MAX_TOKENS=1024

# Model request timeout (seconds)
BUB_MODEL_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Primary API key (required for most providers)
# BUB_API_KEY=sk-...

# Optional custom API base URL
# BUB_API_BASE=https://openrouter.ai/api/v1

# API request format:
# - completion: legacy completion-style requests (default)
# - responses: OpenAI Responses API
# - messages: chat-completions-style messages API
# BUB_API_FORMAT=completion

# -----------------------------------------------------------------------------
# Channel Manager
# -----------------------------------------------------------------------------
# Comma-separated channel names, or `all`.
# `all` excludes the builtin `cli` channel.
# BUB_ENABLED_CHANNELS=all

# Debounce interval (seconds)
BUB_DEBOUNCE_SECONDS=1.0

# Maximum wait time (seconds)
BUB_MAX_WAIT_SECONDS=10.0

# Active time window (seconds)
BUB_ACTIVE_TIME_WINDOW=60.0

# -----------------------------------------------------------------------------
# Telegram Channel (Optional)
# -----------------------------------------------------------------------------
# Bot token from @BotFather
# BUB_TELEGRAM_TOKEN=123456:telegram-bot-token

# Allowed user IDs (comma-separated)
# BUB_TELEGRAM_ALLOW_USERS=123456789,my_username

# Allowed chat IDs (comma-separated, use -100 prefix for supergroups)
# BUB_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890

# Proxy URL (optional, for regions with restricted access)
# BUB_TELEGRAM_PROXY=http://127.0.0.1:1080

# -----------------------------------------------------------------------------
# Example Configurations
# -----------------------------------------------------------------------------
#
# OpenRouter (minimal):
#   BUB_MODEL=openrouter:qwen/qwen3-coder-next
#   BUB_API_KEY=sk-or-...
#
# OpenAI:
#   BUB_MODEL=openai:gpt-4o
#   BUB_API_KEY=sk-...
#
# Local LLM (via OpenAI-compatible API):
#   BUB_MODEL=openai:llama3
#   BUB_API_BASE=http://localhost:11434/v1
#   BUB_API_KEY=ollama
#
# Anthropic:
#   BUB_MODEL=anthropic:claude-sonnet-4-6
#   BUB_API_KEY=sk-ant-...
# =============================================================================